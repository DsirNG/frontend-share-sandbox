# Node backend port. docker-compose.yml maps 127.0.0.1:30003:30003.
PORT=30003
NODE_ENV=production

# MySQL runs on the host server and is shared with xander-lab-backend.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=xander_lab

# Redis is the shared xander-lab Redis container on xander-network.
REDIS_HOST=relationship-redis
REDIS_PORT=6379

# Must match xander-lab-backend so Java-issued tokens can be verified here.
JWT_SECRET=xander-lab-secret-key-must-be-at-least-32-chars-for-hmac

# Upload and retention policy.
MAX_UPLOAD_MB=250
MAX_PROJECTS_PER_USER=20

# Public preview URL returned to xander-lab-frontend.
PREVIEW_URL_PATTERN=https://<projectId>.preview.xander-lab.dsircity.top/

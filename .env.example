# Node 服务端口。docker-compose.yml 已映射 30001:30001。
PORT=30001
NODE_ENV=production

# MySQL 配置。默认连接 xander_lab 远程库，生产部署建议显式填写。
MYSQL_HOST=101.33.246.103
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=xander_lab

# Redis 配置。
# 如果 Redis 安装在宿主机 Linux 上，保持 host.docker.internal，并确保 compose 中 extra_hosts 存在。
# 如果 Redis 是另一个容器，请改成同一 Docker 网络内的 Redis 服务名。
REDIS_HOST=host.docker.internal
REDIS_PORT=6379

# JWT 密钥必须与 Java 后端保持一致，否则 Node 工作室无法识别平台登录 token。
JWT_SECRET=xander-lab-secret-key-must-be-at-least-32-chars-for-hmac

# 上传和项目保留策略。
MAX_UPLOAD_MB=250
MAX_PROJECTS_PER_USER=20

# 预览 URL 模板。生产可改成你的真实域名，例如：
# PREVIEW_URL_PATTERN=https://<projectId>.preview.xander-lab.dsircity.top/
PREVIEW_URL_PATTERN=http://<projectId>.localhost:30001/
